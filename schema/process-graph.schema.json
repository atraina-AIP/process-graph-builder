{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/process-graph.schema.json",
  "$comment": "schema v6 - artifact_refs for server-backed artifact ledger pointers and graph-storage detachment; schema v5 — design-space annotations (variant_of/adoption on node, change on edge, value/cost on flow, top-level design_space); see design-space.schema.json. schema v4 (saved_views) — 2026-06-02: optional top-level `saved_views` array — persistent subgraph view definitions ({ id, name, filter }) that filter/focus the canonical graph without mutating it; each `filter` reuses the quick-filter shape (flow_kinds, edge_types, node_types, focus_selection, hops) and rides along in export. `active_view_id` stays session/UI state and is NOT part of this artifact. v4 base — 2026-06-02: resources are now first-class canvas nodes (node type \"resource\"; its kind/cost_rate/basis_unit live in node attributes) and \"X requires resource Y\" is an allocation edge from the consuming node to the resource node carrying the quantity. The top-level `resources` array and node/edge `resources_required` lists are now OPTIONAL/deprecated — tolerated for migration only, no longer produced or edited by the UI. v3 — 2026-06-02: optional top-level tenant_id stamped on every durable graph (Propel guardrail: no tenant-less production records; durable records are tenant-scoped). Constraint update (2026-06-02): constraints are now free-text — each constraint is a single hand-edited plain-language statement in `expression` (the source of truth); `type` is retained with a default but not shown in the UI; structured `fields` (target/scope/metric/operator/value/unit/notes) are optional and tolerated only for back-compat, no longer read or written by the editor. v2 — 2026-06-02: edge properties/perspectives/description/resources_required; node perspectives; cost resource type + basis_unit; descriptions on edges/resources/constraints; notes optional",
  "title": "ProcessGraph",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "description",
    "modeling_style",
    "nodes",
    "edges",
    "constraints",
    "assumptions",
    "ontology",
    "metadata"
  ],
  "properties": {
    "id": { "type": "string" },
    "tenant_id": {
      "type": "string",
      "description": "Owning tenant for this durable graph. Stamped by the backend on every stored graph; reads/writes are scoped to it so cross-tenant access is not possible by default. Optional in the public schema for back-compat with offline/local-file envelopes that predate tenant scoping."
    },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "modeling_style": {
      "enum": ["none", "business_process", "value_stream", "system_flow", "team_topology", "custom"]
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "resources": {
      "type": "array",
      "items": { "$ref": "#/$defs/resource" }
    },
    "constraints": {
      "type": "array",
      "items": { "$ref": "#/$defs/constraint" }
    },
    "saved_views": {
      "type": "array",
      "items": { "$ref": "#/$defs/saved_view" }
    },
    "design_space": {
      "type": "object",
      "additionalProperties": true,
      "$comment": "Optional design-space export artifact (decision variables, objectives, budgets). Kept permissive here; see design-space.schema.json (#/$defs/design_space) for the full shape."
    },
    "optimization_projection": {
      "type": "object",
      "additionalProperties": true,
      "$comment": "Optional solver/tool projection layer. Preserves LP/Plant JSON relationship terms, objective terms, time_config, validation, and provenance linked back to human-readable ProcessGraph constraints. Plain-language graph.constraints remains source intent."
    },
    "source_artifacts": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true },
      "$comment": "Imported external artifacts (for example canonical Plant JSON) preserved for local file round-trip export and audit. Server-backed saves should store large content in the artifact ledger and leave graph records with artifact_refs."
    },
    "artifact_refs": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true },
      "$comment": "Lightweight references to SQL/blob artifact records used by server-backed graph storage. Carries artifact_id, source_format, hash, byte size, storage_location, and round_trip_role without embedding the full JSON artifact in Cosmos graph records."
    },
    "assumptions": {
      "type": "array",
      "items": { "$ref": "#/$defs/assumption" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "chat_messages": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "versions": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "ontology": { "$ref": "#/$defs/ontology" },
    "metadata": {
      "type": "object",
      "required": ["created_by", "created_at", "tags"],
      "properties": {
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "node": {
      "type": "object",
      "required": [
        "id",
        "name",
        "type",
        "inputs",
        "outputs",
        "attributes"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "enum": ["source", "sink", "task", "decision", "resource"] },
        "description": { "type": "string" },
        "description_status": { "enum": ["empty", "suggested", "custom", "approved"] },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resources_required": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "quantity"],
            "properties": {
              "resource_id": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "attributes": {
          "type": "object",
          "properties": {
            "duration": {},
            "capacity": {},
            "cost": {}
          },
          "additionalProperties": true
        },
        "perspectives": {
          "type": "array",
          "items": { "$ref": "#/$defs/perspective" }
        },
        "variant_of": {
          "type": "string",
          "$comment": "Optional design-space annotation: id of the base node this is an investment variant of. See design-space.schema.json (#/$defs/node_variant_fields)."
        },
        "adoption": {
          "type": "object",
          "additionalProperties": true,
          "$comment": "Optional design-space annotation: one-off cost/time to adopt this variant. See design-space.schema.json (#/$defs/node_variant_fields)."
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "perspective": {
      "type": "object",
      "required": ["label", "text"],
      "properties": {
        "label": { "type": "string" },
        "text": { "type": "string" }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["id", "from_node", "to_node", "type", "condition", "flows"],
      "properties": {
        "id": { "type": "string" },
        "from_node": { "type": "string" },
        "to_node": { "type": "string" },
        "type": { "enum": ["flow", "dependency", "trigger", "feedback", "allocation", "custom"] },
        "condition": { "type": "string" },
        "flows": {
          "type": "array",
          "items": { "$ref": "#/$defs/flow" }
        },
        "resources_required": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "quantity"],
            "properties": {
              "resource_id": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "properties": {
          "type": "object",
          "additionalProperties": true
        },
        "perspectives": {
          "type": "array",
          "items": { "$ref": "#/$defs/perspective" }
        },
        "description": { "type": "string" },
        "description_status": { "enum": ["empty", "suggested", "custom", "approved"] },
        "change": {
          "type": "object",
          "additionalProperties": true,
          "$comment": "Optional design-space annotation: change-moves available on this edge (reroutable/eliminable) with change cost/time. See design-space.schema.json (#/$defs/edge_change)."
        }
      },
      "additionalProperties": false
    },
    "flow": {
      "type": "object",
      "required": ["id", "name", "kind", "quantity", "unit", "properties"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "kind": { "enum": ["parts", "cash", "energy", "information", "data", "work", "approval", "custom"] },
        "quantity": { "type": "string" },
        "unit": { "type": "string" },
        "properties": {
          "type": "object",
          "additionalProperties": true
        },
        "value": {
          "type": "object",
          "additionalProperties": true,
          "$comment": "Optional design-space annotation: flow economics — value as a quantitative parameter. See design-space.schema.json (#/$defs/flow_economics)."
        },
        "cost": {
          "type": "object",
          "additionalProperties": true,
          "$comment": "Optional design-space annotation: flow economics — cost as a quantitative parameter. See design-space.schema.json (#/$defs/flow_economics)."
        }
      },
      "additionalProperties": false
    },
    "resource": {
      "type": "object",
      "required": ["id", "name", "type", "attributes"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "enum": ["human", "machine", "material", "cost"] },
        "attributes": {
          "type": "object",
          "properties": {
            "capacity": {},
            "cost_rate": {},
            "basis_unit": { "type": "string" }
          },
          "additionalProperties": true
        },
        "description": { "type": "string" },
        "description_status": { "enum": ["empty", "suggested", "custom", "approved"] }
      },
      "additionalProperties": false
    },
    "constraint": {
      "type": "object",
      "required": ["id", "type", "expression"],
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["flow_balance", "capability_limit", "timing", "routing_rule", "policy_rule"] },
        "fields": {
          "type": "object",
          "properties": {
            "target": {
              "type": "string",
              "description": "Stable reference value: a node id, edge id, or resource id; the literal \"graph\" for the whole graph; or \"\" when unspecified."
            },
            "scope": {
              "type": "string",
              "description": "Optional free-text qualification of the target (e.g. \"month-end\", \"per shift\")."
            },
            "metric": { "type": "string" },
            "operator": { "type": "string" },
            "value": { "type": "string" },
            "unit": { "type": "string" },
            "notes": { "type": "string" }
          },
          "additionalProperties": true
        },
        "expression": { "type": "string" },
        "description": { "type": "string" },
        "description_status": { "enum": ["empty", "suggested", "custom", "approved"] }
      },
      "additionalProperties": false
    },
    "saved_view": {
      "type": "object",
      "required": ["id", "name", "filter"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "filter": {
          "type": "object",
          "properties": {
            "flow_kinds": { "type": "array", "items": { "type": "string" } },
            "edge_types": { "type": "array", "items": { "type": "string" } },
            "node_types": { "type": "array", "items": { "type": "string" } },
            "focus_selection": { "type": "boolean" },
            "hops": { "type": "number" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "assumption": {
      "type": "object",
      "required": ["id", "text"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ontologyEntry": {
      "type": "object",
      "required": ["label", "description"],
      "properties": {
        "label": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ontology": {
      "type": "object",
      "required": ["modeling_styles", "node_types", "edge_types", "flow_types", "constraint_types", "resource_types", "properties"],
      "properties": {
        "modeling_styles": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/ontologyEntry" }
        },
        "node_types": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/ontologyEntry" }
        },
        "edge_types": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/ontologyEntry" }
        },
        "flow_types": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/ontologyEntry" }
        },
        "constraint_types": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/ontologyEntry" }
        },
        "resource_types": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/ontologyEntry" }
        },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/ontologyEntry" }
        }
      },
      "additionalProperties": true
    }
  }
}
