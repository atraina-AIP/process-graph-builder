{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/process-graph-mutation.schema.json",
  "title": "ProcessGraphMutation",
  "type": "object",
  "required": ["action", "target_id", "payload", "reason", "confidence"],
  "properties": {
    "action": {
      "enum": [
        "add_node",
        "update_node",
        "delete_node",
        "add_edge",
        "update_edge",
        "delete_edge",
        "add_resource",
        "update_resource",
        "add_constraint",
        "update_constraint",
        "add_assumption",
        "add_question"
      ]
    },
    "target_id": {
      "type": ["string", "null"]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "reason": {
      "type": "string"
    },
    "confidence": {
      "enum": ["high", "medium", "low"]
    }
  },
  "additionalProperties": false
}
